# LLM — required for standalone runs (CLI / API); not tied to Cursor or any IDE chat
OPENAI_API_KEY=your_key_here
# Every agent gets an explicit model (independent runs). Priority: ORCHESTRATOR_AGENT_LLM → OPENAI_MODEL_NAME → ORCHESTRATOR_DEFAULT_LLM → gpt-4o-mini
# OPENAI_MODEL_NAME=gpt-4o-mini
# ORCHESTRATOR_DEFAULT_LLM=gpt-4o-mini
# ORCHESTRATOR_AGENT_LLM=gpt-4o
# ORCHESTRATOR_AGENT_REASONING=1
# ORCHESTRATOR_AGENT_MAX_ITER=25

# Reporting Agent — external read-only database (SQLAlchemy URL)
# Example MySQL: mysql+pymysql://user:password@host:3306/database_name
# Example Postgres: postgresql+psycopg2://user:password@host:5432/database_name
# REPORTING_DATABASE_URL=
# Optional: max rows returned per SELECT (default 5000)
# REPORTING_SQL_MAX_ROWS=5000
# Optional: extra instructions for all reporting runs
# REPORTING_CONTEXT=

# Chained SDLC -> Reporting (main.py --with-report): max chars of SDLC output passed to Reporting
# REPORTING_SDLC_CONTEXT_MAX=120000
# Optional defaults for --with-report (overridden by CLI)
# REPORTING_AFTER_SDLC_PROMPT=
# REPORTING_AFTER_SDLC_EXTRA=

# API writes successful runs under each pack: {pack}_agents/Output/{agent_id}/latest.md and history/*.md (set 0 to disable)
# ORCHESTRATOR_SAVE_OUTPUT=1

# HTTP API (api_server.py) — call from any app or chat bot
# ORCHESTRATOR_API_KEY=generate_a_long_random_secret
# Local only: if set, GET /v1/sandbox/ui-bearer (from loopback) returns this key for /app/ to pre-fill Bearer. Never in production.
# ORCHESTRATOR_UI_SANDBOX=1
# Comma-separated origins for CORS (browser apps). Default * (dev only).
# ORCHESTRATOR_CORS_ORIGINS=https://yourapp.com,http://localhost:3000

# Per-agent_id run memory (JSONL; injects past prompts + output excerpts on the next run — not model training)
# AGENT_MEMORY=1
# Default folder (gitignored): .agent_memory/ under the process cwd
# AGENT_MEMORY_DIR=
# AGENT_MEMORY_LAST_N=6
# AGENT_MEMORY_MAX_OUTPUT_CHARS=12000
# AGENT_MEMORY_MAX_INJECT_CHARS=10000

# Six capability layers (see README) — “brain”, memory, tools, perception, planning, governance
# ORCHESTRATOR_AGENT_LLM=  # or use OPENAI_MODEL_NAME — optional LLM for all agents
# ORCHESTRATOR_CAPABILITIES=1   # 0 to disable governance+planning+perception *prefix* (memory & brain still apply)
# ORCHESTRATOR_PERCEPTION=1
# ORCHESTRATOR_PLANNING=1
# ORCHESTRATOR_GOVERNANCE=1
# ORCHESTRATOR_CAPABILITY_TOOL=1   # 0 to hide orchestrator_stack_status tool from agents
# ORCHESTRATOR_MAX_USER_PROMPT_CHARS=48000
# ORCHESTRATOR_MAX_CONTEXT_CHARS=96000
